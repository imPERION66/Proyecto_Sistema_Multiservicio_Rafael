# =========================================================================
# CONFIGURACIÓN DEL FRONTEND PARA DESPLIEGUE (DOKPLOY / VPS)
# =========================================================================

# Puerto en el que escuchará el servidor Express de Angular SSR
PORT=4000

# URL de la API del Backend (usada en el servidor SSR para pre-renderizado)
# En desarrollo local: http://localhost:8080
# En Dokploy (producción): La URL del servicio de backend interno o público (ej. http://backend-inventario:8080 o https://api.tu-dominio.com)
API_URL=http://localhost:8080
